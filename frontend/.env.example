# Base URL of the Python LangGraph backend (FastAPI + SSE).
#
# Local dev:
#   VITE_API_URL=http://localhost:8000
#
# Production (frontend on Vercel, backend on Railway/Render):
#   VITE_API_URL=https://your-backend.up.railway.app
#
# Set this in the Vercel dashboard under Project Settings → Environment Variables.
# (Do NOT commit a populated .env file — only this .env.example template.)
VITE_API_URL=http://localhost:8000
