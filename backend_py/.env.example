# Required
ANTHROPIC_API_KEY=sk-ant-...

# Web search — set at least one. Default priority is Tavily > Serper when
# both are set. Override with SEARCH_BACKEND=serper or SEARCH_BACKEND=tavily.
TAVILY_API_KEY=          # Tavily MCP (https://app.tavily.com)
SERPER_API_KEY=          # Serper.dev — also drives the Google Places call

# Optional — GitHub stats enrichment. With a token: 5,000 core / 30 search
# req/hr. Without: 60 / 10 unauthenticated.
GITHUB_PERSONAL_ACCESS_TOKEN=

# Optional overrides
SEARCH_BACKEND=          # leave blank for auto-select; or set to serper|tavily
CLAUDE_MODEL=claude-sonnet-4-20250514
